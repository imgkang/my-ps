# My PM 백엔드 환경변수 예시 — 이 파일을 복사해 .env 로 만들어 채우세요.
# 절대 실제 값을 커밋하지 마세요. (.env 는 .gitignore 처리됨)

# 서버 포트 (Cloudflare Tunnel 이 이 포트로 프록시)
PORT=3000

# ── 구글 로그인 / 다중 사용자 ──
# 구글 OAuth 웹 클라이언트 ID (Google Cloud Console 에서 발급). 비밀 아님(프론트와 동일 값).
GOOGLE_CLIENT_ID=
# 로그인 허용 이메일 화이트리스트 (콤마 구분). 목록에 없는 계정은 로그인 거부됨.
#   예) ALLOWED_EMAILS=imgkang@gmail.com,wife@gmail.com
ALLOWED_EMAILS=
# 기존(단일 사용자) 데이터를 이관할 소유자 이메일 (migrate/import 에서 사용). 보통 본인 이메일.
OWNER_EMAIL=

# 주가 프록시용 Finnhub API 키 (NonK 미국주식)
# 기존에 NonK.html 에 하드코딩돼 있던 키는 폐기하고 새로 발급받는 것을 권장.
FINNHUB_KEY=

# SQLite DB 파일 경로 (기본: server/data/mypm.db)
DB_PATH=./data/mypm.db

# 프론트 정적 파일 서빙 여부 (로컬 테스트는 true 권장 — 페이지와 API가 한 출처).
# 운영에서 프론트를 GitHub Pages 로만 서빙하면 false 로 꺼도 됨.
SERVE_STATIC=true

# ── GitHub Webhook 자동 배포 ──
# GitHub 저장소 → Settings → Webhooks → Add webhook
#   Payload URL: https://mypm.growpension.com/api/github-webhook
#   Content type: application/json
#   Secret: 아래 값 (openssl rand -hex 32 로 생성 권장)
GITHUB_WEBHOOK_SECRET=

# Cloudflare 캐시 퍼지 (git pull 후 자동 실행)
#   Zone ID: Cloudflare 대시보드 → growpension.com → 우측 하단 Zone ID
#   API Token: My Profile → API Tokens → Create Token (Cache Purge 권한)
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# ── 푸시 알림 ──
# iOS (APNs) — Apple Developer 에서 발급한 .p8 키. (Phase 5, Mac/iOS 단계)
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
# production | development
APNS_ENV=development

# Android (FCM) — Firebase 콘솔에서 발급한 서비스 계정 키(JSON) 파일 경로.
# 이 JSON 자체가 비밀이므로 .env 와 함께 gitignore 되는 경로에 두세요.
FCM_SERVICE_ACCOUNT_PATH=
