# My PM 백엔드 환경변수 예시 — 이 파일을 복사해 .env 로 만들어 채우세요.
# 절대 실제 값을 커밋하지 마세요. (.env 는 .gitignore 처리됨)

# 서버 포트 (Cloudflare Tunnel 이 이 포트로 프록시)
PORT=3000

# 가족 공유 인증 PIN — 앱에서 이 값으로 로그인하면 토큰을 발급받음
# 충분히 긴 임의 문자열로 설정하세요.
APP_PIN=change-me-to-a-long-secret

# 주가 프록시용 Finnhub API 키 (NonK 미국주식)
# 기존에 NonK.html 에 하드코딩돼 있던 키는 폐기하고 새로 발급받는 것을 권장.
FINNHUB_KEY=

# SQLite DB 파일 경로 (기본: server/data/mypm.db)
DB_PATH=./data/mypm.db

# 프론트 정적 파일 서빙 여부 (로컬 테스트는 true 권장 — 페이지와 API가 한 출처).
# 운영에서 프론트를 GitHub Pages 로만 서빙하면 false 로 꺼도 됨.
SERVE_STATIC=true

# ── 푸시 알림 ──
# iOS (APNs) — Apple Developer 에서 발급한 .p8 키. (Phase 5, Mac/iOS 단계)
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
# production | development
APNS_ENV=development

# Android (FCM) — Firebase 콘솔에서 발급한 서비스 계정 키(JSON) 파일 경로.
# 이 JSON 자체가 비밀이므로 .env 와 함께 gitignore 되는 경로에 두세요.
FCM_SERVICE_ACCOUNT_PATH=
